<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no">
<title>בטן רגועה</title>
<meta name="theme-color" content="#FFF8F3">
<link rel="manifest" href="manifest.webmanifest">
<link rel="apple-touch-icon" href="icons/icon-180.png">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="בטן רגועה">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Varela+Round&family=Assistant:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#FFF7F1; --card:#FFFFFF; --ink:#43304A; --soft:#947E9C;
  --coral:#F4867C; --coral-deep:#E85D68; --coral-soft:#FFE9E4;
  --sage:#69BFA5; --sage-soft:#E3F5EC; --lilac:#A98BE0; --lilac-soft:#F1EAFC;
  --sun:#F7B24C; --sun-soft:#FEF0DA; --pink:#EC6FA8;
  --acc:var(--coral); --acc-soft:var(--coral-soft);
  --radius:24px; --shadow:0 8px 28px rgba(67,48,74,.09);
  --safe-b:env(safe-area-inset-bottom,0px);
}
*{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
html,body{margin:0; padding:0; background:var(--bg); color:var(--ink);
  font-family:'Assistant',-apple-system,sans-serif; font-size:16px;}
body{padding-bottom:calc(92px + var(--safe-b)); overscroll-behavior-y:none; min-height:100vh;}
body::before{content:""; position:fixed; inset:0; z-index:-1; pointer-events:none;
  background:
    radial-gradient(420px 420px at 90% -5%, rgba(244,134,124,.16), transparent 65%),
    radial-gradient(380px 380px at -10% 25%, rgba(169,139,224,.14), transparent 65%),
    radial-gradient(460px 460px at 110% 85%, rgba(105,191,165,.13), transparent 65%),
    radial-gradient(300px 300px at 20% 105%, rgba(247,178,76,.12), transparent 65%);}
h1,h2,h3,.display{font-family:'Varela Round','Assistant',sans-serif; font-weight:400;}
button{font-family:inherit; border:none; background:none; color:inherit; cursor:pointer;}
input,textarea,select{font-family:inherit; font-size:16px; color:var(--ink);}

/* ---------- header ---------- */
header{padding:calc(16px + env(safe-area-inset-top,0px)) 20px 6px;}
.day-bubble{position:relative; overflow:hidden; border-radius:32px; padding:22px 22px 20px;
  background:linear-gradient(130deg,#FFE3D8 0%,#FBD9E8 45%,#E9DDFB 100%);
  box-shadow:0 12px 32px rgba(233,93,104,.16);}
.day-bubble .orb{position:absolute; border-radius:50%; filter:blur(2px); opacity:.7; pointer-events:none;}
.orb.o1{width:90px;height:90px; background:rgba(255,255,255,.55); top:-30px; left:14%;
  animation:drift 9s ease-in-out infinite;}
.orb.o2{width:56px;height:56px; background:rgba(255,255,255,.4); bottom:-16px; left:55%;
  animation:drift 12s ease-in-out infinite reverse;}
.orb.o3{width:26px;height:26px; background:rgba(255,255,255,.65); top:18px; left:78%;
  animation:drift 7s ease-in-out infinite;}
@keyframes drift{0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(14px,10px) scale(1.12);}}
.day-bubble h1{margin:0; font-size:1.65rem; position:relative;}
.day-bubble p{margin:5px 0 0; color:#8A6E93; font-size:.95rem; position:relative; font-weight:600;}

/* ---------- tabs / pages ---------- */
.page{display:none; padding:16px 18px 10px; animation:fade .3s ease;}
.page.active{display:block;}
@keyframes fade{from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:none;}}
@keyframes rise{from{opacity:0; transform:translateY(14px) scale(.98);} to{opacity:1; transform:none;}}
nav{position:fixed; bottom:0; right:0; left:0; z-index:40;
  background:rgba(255,255,255,.85); backdrop-filter:blur(18px); -webkit-backdrop-filter:blur(18px);
  border-top:1px solid rgba(241,230,238,.9); display:flex;
  padding:9px 8px calc(9px + var(--safe-b)); box-shadow:0 -6px 24px rgba(67,48,74,.06);}
nav button{flex:1; display:flex; flex-direction:column; align-items:center; gap:3px;
  font-size:.72rem; font-weight:700; color:#B7A5BE; padding:8px 0 7px; border-radius:18px;
  transition:all .25s;}
nav button .ic{font-size:1.4rem; line-height:1; transition:transform .25s;}
nav button.on{color:var(--coral-deep);
  background:linear-gradient(135deg,var(--coral-soft),#FBE4F0);}
nav button.on .ic{transform:translateY(-2px) scale(1.15);}

/* ---------- timeline ---------- */
.day-group{margin:20px 0 6px;}
.day-title{font-family:'Varela Round'; font-size:1.05rem; color:var(--soft); margin:0 6px 12px;
  display:flex; align-items:center; gap:8px;}
.day-title::after{content:""; flex:1; height:2px; border-radius:2px;
  background:linear-gradient(270deg,transparent,#F0DFEE);}
.tl{position:relative; padding-right:28px;}
.tl::before{content:""; position:absolute; right:9px; top:8px; bottom:8px; width:3px; border-radius:3px;
  background:linear-gradient(180deg,var(--coral),var(--lilac),var(--sage));}
.entry{position:relative; background:var(--card); border-radius:var(--radius);
  box-shadow:var(--shadow); padding:13px 15px; margin-bottom:13px;
  border-right:5px solid var(--coral); animation:rise .35s ease both;}
.entry:nth-child(2){animation-delay:.05s;} .entry:nth-child(3){animation-delay:.1s;}
.entry:nth-child(4){animation-delay:.15s;} .entry:nth-child(n+5){animation-delay:.2s;}
.entry::before{content:""; position:absolute; right:-25px; top:19px; width:11px; height:11px;
  border-radius:50%; background:var(--coral); box-shadow:0 0 0 4px var(--bg),0 0 0 6px var(--coral-soft);}
.entry.k-feel{border-right-color:var(--lilac);} .entry.k-feel::before{background:var(--lilac); box-shadow:0 0 0 4px var(--bg),0 0 0 6px var(--lilac-soft);}
.entry.k-voice{border-right-color:var(--sage);} .entry.k-voice::before{background:var(--sage); box-shadow:0 0 0 4px var(--bg),0 0 0 6px var(--sage-soft);}
.entry.k-note{border-right-color:var(--sun);} .entry.k-note::before{background:var(--sun); box-shadow:0 0 0 4px var(--bg),0 0 0 6px var(--sun-soft);}
.e-top{display:flex; align-items:center; gap:9px;}
.e-emoji{font-size:1.35rem;}
.e-title{font-weight:700; flex:1; font-size:1.02rem;}
.e-time{color:var(--soft); font-size:.84rem; font-weight:700; background:#F8F2F7;
  border-radius:999px; padding:2px 10px;}
.e-del{color:#DCC9DA; font-size:1.05rem; padding:2px 6px;}
.e-text{margin:7px 2px 0; line-height:1.5;}
.chips{display:flex; flex-wrap:wrap; gap:6px; margin-top:9px;}
.chip{background:var(--lilac-soft); color:#7458A0; border-radius:999px;
  padding:4px 12px; font-size:.83rem; font-weight:600;}
.chip.sev1{background:var(--sun-soft); color:#A5741B;}
.chip.sev2{background:#FDE0CB; color:#BC5F22;}
.chip.sev3{background:var(--coral-soft); color:#CE4550;}
.chip.good{background:var(--sage-soft); color:#3E8A6E;}
.entry audio{width:100%; margin-top:9px; height:38px;}
.empty{text-align:center; color:var(--soft); padding:48px 20px; animation:rise .4s ease;}
.empty .big{font-size:3rem; display:block; animation:drift 5s ease-in-out infinite;}

/* ---------- FAB ---------- */
#fab{position:fixed; left:20px; bottom:calc(102px + var(--safe-b)); z-index:41;
  width:62px; height:62px; border-radius:50%; font-size:2rem; color:#fff;
  background:linear-gradient(135deg,var(--coral) 0%,var(--coral-deep) 60%,var(--pink) 120%);
  box-shadow:0 10px 26px rgba(233,93,104,.45), inset 0 2px 6px rgba(255,255,255,.35);
  display:flex; align-items:center; justify-content:center; animation:float 3.5s ease-in-out infinite;}
@keyframes float{0%,100%{transform:translateY(0);} 50%{transform:translateY(-5px);}}
#fab:active{transform:scale(.92); animation:none;}

/* ---------- hearts burst ---------- */
.heart{position:fixed; z-index:70; font-size:1.15rem; pointer-events:none;
  animation:heartUp 1.1s ease-out forwards;}
@keyframes heartUp{
  0%{opacity:1; transform:translate(0,0) scale(.6) rotate(0);}
  100%{opacity:0; transform:translate(var(--hx),-90px) scale(1.25) rotate(var(--hr));}}

/* ---------- sheet ---------- */
#overlay{position:fixed; inset:0; background:rgba(67,48,74,.4); z-index:50;
  opacity:0; pointer-events:none; transition:opacity .25s; backdrop-filter:blur(2px);}
#overlay.show{opacity:1; pointer-events:auto;}
#sheet{position:fixed; right:0; left:0; bottom:0; z-index:51; background:var(--card);
  border-radius:30px 30px 0 0; padding:14px 20px calc(22px + var(--safe-b));
  transform:translateY(105%); transition:transform .38s cubic-bezier(.22,1.2,.36,1);
  max-height:88vh; overflow-y:auto; box-shadow:0 -12px 40px rgba(67,48,74,.18);}
#sheet.show{transform:none;}
.grip{width:44px; height:5px; border-radius:3px; background:#EDDFEB; margin:0 auto 14px;}
.seg{display:flex; background:#F7F0F6; border-radius:18px; padding:5px; gap:5px; margin-bottom:16px;}
.seg button{flex:1; padding:10px 2px; border-radius:14px; font-size:.85rem; color:var(--soft);
  font-weight:700; transition:all .2s;}
.seg button.on{background:#fff; color:var(--coral-deep);
  box-shadow:0 3px 10px rgba(67,48,74,.12); transform:scale(1.03);}
.f-label{font-weight:700; margin:15px 2px 8px; font-size:.95rem;}
.pick{display:flex; flex-wrap:wrap; gap:8px;}
.pick button{background:#F7F0F6; border-radius:999px; padding:9px 15px; font-size:.9rem;
  font-weight:600; transition:transform .15s;}
.pick button.on{background:var(--coral-soft); color:var(--coral-deep); font-weight:700;
  outline:2px solid var(--coral); animation:pop .25s ease;}
@keyframes pop{50%{transform:scale(1.12);}}
.pick.lil button.on{background:var(--lilac-soft); color:#7458A0; outline-color:var(--lilac);}
.pick.sag button.on{background:var(--sage-soft); color:#3E8A6E; outline-color:var(--sage);}
textarea.f-in, input.f-in{width:100%; border:2px solid #F1E5F0; border-radius:18px;
  padding:13px 15px; background:#FDFAFC; resize:none; outline:none; transition:border-color .2s;}
textarea.f-in:focus, input.f-in:focus{border-color:var(--lilac);}
input[type=datetime-local]{direction:ltr; text-align:right;}
.save-btn{width:100%; margin-top:20px; padding:16px; border-radius:20px; color:#fff;
  font-size:1.08rem; font-weight:700; letter-spacing:.2px;
  background:linear-gradient(135deg,var(--coral),var(--coral-deep) 70%,var(--pink));
  box-shadow:0 8px 20px rgba(233,93,104,.35);}
.save-btn:active{transform:scale(.98);}
.save-btn:disabled{opacity:.45;}

/* ---------- recorder ---------- */
.rec-wrap{text-align:center; padding:10px 0;}
#recBtn{width:92px; height:92px; border-radius:50%; font-size:2.3rem;
  background:radial-gradient(circle at 35% 30%,#fff,var(--coral-soft)); transition:all .2s;
  margin:8px 0; box-shadow:var(--shadow);}
#recBtn.live{background:linear-gradient(135deg,var(--coral),var(--coral-deep)); color:#fff;
  animation:pulse 1.2s infinite;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(244,134,124,.5);} 50%{box-shadow:0 0 0 18px rgba(244,134,124,0);}}
#recTime{font-family:'Varela Round'; font-size:1.25rem; color:var(--soft);}
#recPrev{width:100%; margin-top:10px;}
.rec-hint{color:var(--soft); font-size:.9rem; font-weight:600;}

/* ---------- meals ---------- */
.cat-row{display:flex; gap:9px; overflow-x:auto; padding:4px 2px 14px; -webkit-overflow-scrolling:touch;}
.cat-row::-webkit-scrollbar{display:none;}
.cat-row button{white-space:nowrap; background:#fff; box-shadow:var(--shadow);
  border-radius:999px; padding:10px 17px; font-size:.93rem; color:var(--soft);
  font-weight:700; transition:all .2s;}
.cat-row button.on{color:#fff; transform:translateY(-1px);
  background:linear-gradient(135deg,var(--acc),var(--acc)); box-shadow:0 6px 16px var(--acc-soft);}
.bank-note{background:linear-gradient(120deg,var(--sage-soft),#F2FBF0); border-radius:20px;
  padding:12px 15px; font-size:.9rem; color:#3E8A6E; margin-bottom:12px; line-height:1.45; font-weight:600;}
.meal-card{background:var(--card); border-radius:var(--radius); box-shadow:var(--shadow);
  padding:16px; margin-bottom:15px; border-top:5px solid var(--acc); animation:rise .35s ease both;}
.meal-card:nth-child(2){animation-delay:.06s;} .meal-card:nth-child(3){animation-delay:.12s;}
.meal-card:nth-child(4){animation-delay:.18s;} .meal-card:nth-child(n+5){animation-delay:.24s;}
.m-head{display:flex; align-items:center; gap:12px;}
.m-emoji{font-size:1.6rem; width:52px; height:52px; border-radius:18px; background:var(--acc-soft);
  display:flex; align-items:center; justify-content:center; flex-shrink:0;}
.m-name{font-family:'Varela Round'; font-size:1.12rem; flex:1;}
.m-parts{margin:11px 2px 0; padding:0; list-style:none; line-height:1.7; font-size:.95rem;}
.m-parts li::before{content:"•"; color:var(--acc); margin-left:8px; font-size:1.1rem;}
.m-swaps-t{font-size:.82rem; color:var(--soft); margin:11px 2px 6px; font-weight:700;}
.meal-card .chip{background:var(--acc-soft); color:var(--ink); opacity:.85;}
.m-log{margin-top:13px; background:var(--sage-soft); color:#3E8A6E; font-weight:700;
  border-radius:15px; padding:10px 17px; font-size:.9rem; transition:transform .15s;}
.m-log:active{transform:scale(.96);}
.shuffle{width:100%; margin:2px 0 15px; padding:14px; border-radius:20px; color:#fff;
  font-weight:700; font-size:.98rem; position:relative; overflow:hidden;
  background:linear-gradient(120deg,var(--lilac),var(--pink),var(--coral));
  background-size:220% 100%; animation:shimmer 6s linear infinite;
  box-shadow:0 8px 20px rgba(169,139,224,.35);}
@keyframes shimmer{0%{background-position:0 0;} 100%{background-position:220% 0;}}
.shuffle:active{transform:scale(.98);}

/* ---------- tips ---------- */
.tip{background:var(--card); border-radius:var(--radius); box-shadow:var(--shadow);
  padding:15px 16px; margin-bottom:12px; display:flex; gap:13px; align-items:flex-start;
  animation:rise .35s ease both;}
.tip:nth-child(2){animation-delay:.05s;} .tip:nth-child(3){animation-delay:.1s;}
.tip:nth-child(n+4){animation-delay:.15s;}
.tip .t-e{font-size:1.55rem; width:48px; height:48px; border-radius:16px; background:#F8F2F7;
  display:flex; align-items:center; justify-content:center; flex-shrink:0;}
.tip p{margin:0; line-height:1.55;}
.tip b{display:block; font-size:1.02rem;}
.breath{background:linear-gradient(135deg,#EFE4FC,#DFF3E9); border-radius:28px;
  box-shadow:var(--shadow); padding:22px; text-align:center; margin-bottom:15px; overflow:hidden;}
#bCircle{width:118px; height:118px; margin:16px auto; border-radius:50%;
  background:radial-gradient(circle at 32% 30%, #fff 0%, #E4D4FB 55%, var(--lilac) 100%);
  box-shadow:0 10px 26px rgba(169,139,224,.4), inset 0 3px 10px rgba(255,255,255,.7);
  transition:transform 1s linear; display:flex; align-items:center; justify-content:center;
  font-family:'Varela Round'; font-size:1.3rem; color:#5F4880;}
.breath b{font-size:1.15rem;}
.breath button{background:#fff; border-radius:999px; padding:11px 26px; font-weight:700;
  color:#7458A0; box-shadow:var(--shadow); font-size:.97rem;}
.doctor{background:linear-gradient(120deg,var(--sun-soft),#FFF6E4); border-radius:var(--radius);
  padding:15px 16px; font-size:.92rem; line-height:1.6; color:#8A6516; margin-bottom:12px;}

/* ---------- summary ---------- */
.stat-grid{display:grid; grid-template-columns:1fr 1fr; gap:13px; margin-bottom:15px;}
.stat{background:var(--card); border-radius:var(--radius); box-shadow:var(--shadow);
  padding:16px 12px; text-align:center; animation:rise .35s ease both;}
.stat:nth-child(2){animation-delay:.06s;} .stat:nth-child(3){animation-delay:.12s;}
.stat:nth-child(4){animation-delay:.18s;}
.stat .n{font-family:'Varela Round'; font-size:1.9rem;
  background:linear-gradient(135deg,var(--coral-deep),var(--pink));
  -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent;}
.stat .l{color:var(--soft); font-size:.85rem; font-weight:600;}
.sum-btn{width:100%; padding:15px; border-radius:20px; font-weight:700; margin-bottom:11px;
  background:var(--card); box-shadow:var(--shadow); color:var(--ink); font-size:.97rem;}
.sum-btn.main{background:linear-gradient(135deg,var(--coral),var(--coral-deep) 70%,var(--pink));
  color:#fff; box-shadow:0 8px 20px rgba(233,93,104,.35);}
#toast{position:fixed; bottom:calc(110px + var(--safe-b)); right:50%;
  transform:translateX(50%) translateY(20px);
  background:var(--ink); color:#fff; border-radius:999px; padding:11px 22px; font-size:.9rem;
  font-weight:600; opacity:0; transition:all .25s; z-index:60; pointer-events:none;
  white-space:nowrap; box-shadow:0 8px 24px rgba(67,48,74,.3);}
#toast.show{opacity:1; transform:translateX(50%);}
@media (prefers-reduced-motion:reduce){ *{animation:none!important; transition:none!important;} }
</style>
</head>
<body>

<header><div class="day-bubble"><span class="orb o1"></span><span class="orb o2"></span><span class="orb o3"></span><h1 id="hello">היי 💛</h1><p id="hSub"></p></div></header>

<!-- ============ יומן ============ -->
<section class="page active" id="p-diary">
  <div id="timeline"></div>
</section>

<!-- ============ ארוחות ============ -->
<section class="page" id="p-meals">
  <div class="bank-note">רעיונות לארוחות שבדרך כלל נעימות יותר לבטן. זה לא "מותר ואסור", זו התחלה נוחה, ואפשר להחליף כל דבר 💛</div>
  <div class="cat-row" id="catRow"></div>
  <button class="shuffle" id="shuffleBtn">🎲 הגרילי לי משהו מהקטגוריה</button>
  <div id="mealList"></div>
</section>

<!-- ============ טיפים ============ -->
<section class="page" id="p-tips">
  <div class="breath">
    <b class="display">נשימת בטן רגועה</b>
    <div id="bCircle">מוכנה?</div>
    <div id="bText" style="color:#6F5590;min-height:22px;margin-bottom:10px;">שאיפה 4 · החזקה 4 · נשיפה 6</div>
    <button id="bStart">התחלה</button>
  </div>
  <div id="tipList"></div>
  <div class="doctor"><b>🩺 מתי כדאי לספר לאמא/אבא ולרופא?</b><br>
  ירידה במשקל, דם ביציאה, חום ממושך, הקאות חוזרות, כאב שמעיר משינה, או חולשה חריגה. אלה דברים שרופא צריך לבדוק.</div>
  <p style="color:var(--soft);font-size:.82rem;text-align:center;line-height:1.5;">האפליקציה היא כלי עזר בלבד ואינה תחליף לרופא או לדיאטנית.</p>
</section>

<!-- ============ סיכום ============ -->
<section class="page" id="p-sum">
  <h2 class="display" style="margin:4px 2px 12px;">14 הימים האחרונים</h2>
  <div class="stat-grid" id="statGrid"></div>
  <button class="sum-btn main" id="shareBtn">📤 שיתוף סיכום לדיאטנית / להורים</button>
  <button class="sum-btn" id="backupBtn">💾 גיבוי היומן (קובץ)</button>
  <button class="sum-btn" id="restoreBtn">📥 שחזור מגיבוי</button>
  <input type="file" id="restoreFile" accept="application/json" hidden>
  <p style="color:var(--soft);font-size:.82rem;text-align:center;">הקלטות קול נשמרות רק במכשיר ולא נכללות בסיכום הטקסט.</p>
</section>

<button id="fab" aria-label="הוספה">＋</button>

<nav>
  <button data-p="p-diary" class="on"><span class="ic">📖</span>היומן שלי</button>
  <button data-p="p-meals"><span class="ic">🍽️</span>ארוחות</button>
  <button data-p="p-tips"><span class="ic">🌸</span>טיפים</button>
  <button data-p="p-sum"><span class="ic">✨</span>סיכום</button>
</nav>

<!-- ============ add sheet ============ -->
<div id="overlay"></div>
<div id="sheet">
  <div class="grip"></div>
  <div class="seg" id="kindSeg">
    <button data-k="meal" class="on">🍽️ ארוחה</button>
    <button data-k="feel">💜 הרגשה</button>
    <button data-k="voice">🎙️ הקלטה</button>
    <button data-k="note">📝 פתק</button>
  </div>

  <div id="f-meal">
    <div class="f-label">איזו ארוחה?</div>
    <div class="pick" id="mealTypePick"></div>
    <div class="f-label">מה אכלתי?</div>
    <textarea class="f-in" id="mealText" rows="2" placeholder="למשל: דייסת שיבולת שועל עם בננה"></textarea>
  </div>

  <div id="f-feel" hidden>
    <div class="f-label">מה מרגישה?</div>
    <div class="pick lil" id="sympPick"></div>
    <div class="f-label" id="sevLabel">כמה חזק?</div>
    <div class="pick" id="sevPick"></div>
    <div class="f-label">קרה משהו מסביב? (לא חובה)</div>
    <div class="pick sag" id="ctxPick"></div>
    <div class="f-label">עוד משהו?</div>
    <textarea class="f-in" id="feelText" rows="2" placeholder="לא חובה..."></textarea>
  </div>

  <div id="f-voice" hidden>
    <div class="rec-wrap">
      <div class="rec-hint">מספרים לבטן-יומן מה קרה 🎙️</div>
      <button id="recBtn">🎙️</button>
      <div id="recTime">0:00</div>
      <audio id="recPrev" controls hidden></audio>
    </div>
    <textarea class="f-in" id="voiceText" rows="1" placeholder="כותרת קצרה (לא חובה)"></textarea>
  </div>

  <div id="f-note" hidden>
    <div class="f-label">מה על הלב?</div>
    <textarea class="f-in" id="noteText" rows="3" placeholder="כל דבר..."></textarea>
  </div>

  <div class="f-label">מתי זה היה?</div>
  <input type="datetime-local" class="f-in" id="whenIn">
  <button class="save-btn" id="saveBtn">שמירה ביומן 💛</button>
</div>

<div id="toast"></div>

<script>
"use strict";
/* ================= data ================= */
const LS_KEY="beten.entries.v1";
let entries=[]; try{entries=JSON.parse(localStorage.getItem(LS_KEY)||"[]");}catch(e){entries=[];}
const save=()=>localStorage.setItem(LS_KEY,JSON.stringify(entries));
const uid=()=>Date.now().toString(36)+Math.random().toString(36).slice(2,7);

/* ---------- IndexedDB for audio ---------- */
let db=null;
const dbReady=new Promise(res=>{
  const rq=indexedDB.open("beten-audio",1);
  rq.onupgradeneeded=e=>e.target.result.createObjectStore("clips");
  rq.onsuccess=e=>{db=e.target.result;res();};
  rq.onerror=()=>res();
});
function putClip(id,blob){return dbReady.then(()=>new Promise(r=>{
  if(!db)return r(false);
  const tx=db.transaction("clips","readwrite"); tx.objectStore("clips").put(blob,id);
  tx.oncomplete=()=>r(true); tx.onerror=()=>r(false);}));}
function getClip(id){return dbReady.then(()=>new Promise(r=>{
  if(!db)return r(null);
  const rq=db.transaction("clips").objectStore("clips").get(id);
  rq.onsuccess=()=>r(rq.result||null); rq.onerror=()=>r(null);}));}
function delClip(id){return dbReady.then(()=>new Promise(r=>{
  if(!db)return r();
  const tx=db.transaction("clips","readwrite"); tx.objectStore("clips").delete(id);
  tx.oncomplete=r; tx.onerror=r;}));}

/* ================= constants ================= */
const MEAL_TYPES=[["boker","🌅 בוקר"],["tsohor","🌞 צהריים"],["erev","🌙 ערב"],["nash","🍿 נשנוש"],["school","🎒 בית ספר"]];
const SYMPTOMS=["כאב בטן","נפיחות","גזים","בחילה","צרבת","יציאה רכה","עצירות","הכול טוב 💛"];
const SEVS=[["1","קצת"],["2","בינוני"],["3","חזק"]];
const CTX=["לחץ","מבחן","מעט שינה","מחזור","ספורט","אכלתי מהר","ארוחה גדולה"];
const DAYS=["ראשון","שני","שלישי","רביעי","חמישי","שישי","שבת"];

const MEALS={
 "בוקר":[
  {e:"🥣",n:"דייסת שיבולת שועל",p:["שיבולת שועל על מים או חלב ללא לקטוז","בננה פרוסה","קינמון"],s:["תותים","אוכמניות","כפית ממרח בוטנים","מייפל מעט"]},
  {e:"🍳",n:"חביתה וטוסט",p:["חביתה מ-2 ביצים","לחם כוסמין 100% קלוי או לחם ללא גלוטן","מלפפון ועגבנייה"],s:["ביצה קשה","ביצת עין","פרוסת גבינה צהובה"]},
  {e:"🍓",n:"יוגורט ופירות",p:["יוגורט ללא לקטוז","תותים או קיווי","כף שיבולת שועל קלויה"],s:["בננה","כף זרעי צ'יה מושרים","גרנולה ביתית משיבולת שועל"]},
  {e:"🥞",n:"פנקייק בננה",p:["בננה מעוכה + ביצה + שיבולת שועל טחונה","מעט מייפל"],s:["קינמון","תותים מעל","יוגורט ללא לקטוז בצד"]},
  {e:"🥪",n:"כריך בוקר",p:["לחם מתאים (כוסמין 100% / ללא גלוטן)","טחינה גולמית או גבינה צהובה","ירקות"],s:["גבינה לבנה ללא לקטוז","ממרח בוטנים","ביצה קשה"]}],
 "צהריים":[
  {e:"🍗",n:"שניצל ואורז",p:["שניצל עוף אפוי בציפוי פירורי אורז או קורנפלקס","אורז לבן","מלפפון וגזר"],s:["פירה","שעועית ירוקה מאודה","סלט עגבניות"]},
  {e:"🍝",n:"פסטה ברוטב עגבניות ביתי",p:["פסטה ללא גלוטן או פסטת אורז","רוטב עגבניות בלי בצל ושום. הטריק: שמן זית בטעם שום נותן את הטעם בלי הכאב","גבינה קשה מגוררת"],s:["קוביות חזה עוף","טונה","קישוא מוקפץ"]},
  {e:"🍠",n:"עוף ותפוחי אדמה בתנור",p:["פרגית או חזה עוף","תפוחי אדמה אפויים","גזר וקישוא בתנור"],s:["מעט בטטה","דלעת","אורז"]},
  {e:"🐟",n:"דג ואורז",p:["סלמון או דניס בתנור עם לימון","אורז","סלט מלפפונים"],s:["פירה","שעועית ירוקה","עגבניות שרי"]},
  {e:"🧆",n:"קציצות עוף אפויות",p:["קציצות עוף עם גזר מגורר ועשבי תיבול (בלי בצל)","אורז או פתיתי אורז","ירקות מאודים"],s:["פעם בשבוע: קציצות בקר רזה (ברזל!)","קינואה","רוטב עגבניות ביתי"]}],
 "ערב":[
  {e:"🍳",n:"חביתה וסלט",p:["חביתה","סלט מלפפונים ועגבניות","פריכיות אורז או לחם מתאים"],s:["גבינה לבנה ללא לקטוז","זיתים","אבוקדו רבע (כמות קטנה)"]},
  {e:"🥪",n:"כריך טונה",p:["טונה עם טחינה גולמית ולימון (עדיף על מיונז, מוסיף סידן וברזל)","לחם מתאים","מלפפון"],s:["ביצה קשה במקום טונה","מעט מיונז אם ממש מעדיפה","עגבנייה וחסה"]},
  {e:"🍅",n:"שקשוקה עדינה",p:["ביצים ברוטב עגבניות ביתי בלי בצל ושום","מעט פלפל אדום","לחם מתאים לניגוב"],s:["פטרוזיליה","מעט גבינה בולגרית מעל","קוביות קישוא ברוטב"]},
  {e:"🍲",n:"מרק ירקות עדין",p:["גזר, קישוא, תפוח אדמה ודלעת","מעט אורז בפנים"],s:["אטריות אורז","קוביות עוף","עשבי תיבול"]},
  {e:"🍚",n:"אורז מוקפץ עדין",p:["אורז","ביצה טרופה","גזר + החלק הירוק של בצל ירוק","מעט רוטב סויה ללא גלוטן"],s:["קוביות עוף","קישוא","שומשום מעט"]},
  {e:"🧀",n:"טוסט גבינה",p:["לחם מתאים","גבינה צהובה קשה","עגבנייה"],s:["זיתים","ביצה קשה בצד","מלפפונים חמוצים מעט"]}],
 "נשנושים":[
  {e:"🍌",n:"פרי קל לבטן",p:["בננה / מנדרינה / ענבים / תותים / קיווי / מלון כתום"],s:["אוכמניות","קלמנטינה"]},
  {e:"🍿",n:"פופקורן ביתי",p:["פופקורן בסיר עם מעט שמן ומלח"],s:["מעט פפריקה"]},
  {e:"🥜",n:"פריכיות וממרח בוטנים",p:["פריכיות אורז","ממרח בוטנים טבעי"],s:["בננה פרוסה מעל","שוקולד מריר מגורר מעט"]},
  {e:"🥕",n:"ירקות ומטבל",p:["מקלות גזר ומלפפון","מטבל טחינה-לימון או יוגורט ללא לקטוז עם שמיר"],s:["פלפל אדום (כמות קטנה)","זיתים"]},
  {e:"🌰",n:"חופן קטן אגוזים",p:["בוטנים או אגוזי מלך, חופן קטן"],s:["גרעיני דלעת"]}],
 "קינוחים":[
  {e:"🍫",n:"שוקולד מריר",p:["2-3 קוביות שוקולד מריר"],s:["עם תותים"]},
  {e:"🍧",n:"סורבה או ג'לטי",p:["סורבה פירות (עדיף תות/לימון)"],s:["ארטיק קרח"]},
  {e:"🍰",n:"עוגת בננה ביתית",p:["על בסיס שיבולת שועל ובננה"],s:["קינמון","מעט שוקולד צ'יפס מריר"]},
  {e:"🍬",n:"מרנג",p:["נשיקות מרנג קטנות"],s:["-"]},
  {e:"🍌",n:"בננה קפואה בשוקולד",p:["פרוסות בננה קפואות","מעט שוקולד מריר מומס"],s:["פירורי בוטנים"]},
  {e:"🥥",n:"פודינג צ'יה",p:["2 כפות זרעי צ'יה מושרים לילה בחלב ללא לקטוז","תותים מעל"],s:["קינמון","מעט מייפל","קיווי"]}],
 "לבית הספר":[
  {e:"🥪",n:"כריך גבינה צהובה",p:["לחם מתאים","גבינה צהובה","מלפפון"],s:["טחינה גולמית","ביצה קשה","זיתים"]},
  {e:"🥪",n:"כריך ממרח בוטנים",p:["לחם מתאים","ממרח בוטנים טבעי","בננה פרוסה (אופציה)"],s:["ריבת תות מעט"]},
  {e:"🥒",n:"קופסת ירקות ופריכיות",p:["מלפפון, גזר, עגבניות שרי","פריכיות אורז"],s:["פלפל (כמות קטנה)"]},
  {e:"🍇",n:"קופסת פירות",p:["ענבים / תותים / מנדרינה מקולפת"],s:["קיווי חתוך"]},
  {e:"💧",n:"תמיד בתיק",p:["בקבוק מים","נשנוש קטן ליום ארוך (פופקורן/פריכיות)"],s:["-"]}]
};

const TIPS=[
 ["🐢","לאט זה חזק","לאכול לאט וללעוס טוב. הבטן אוהבת קצב רגוע, וזה אחד הדברים שהכי עוזרים לנפיחות."],
 ["⏰","ארוחות קבועות","לא לדלג על ארוחות ולא להגיע רעבה מדי. ארוחות בינוניות עדיפות על ארוחה ענקית אחת."],
 ["💧","מים לאורך היום","ופחות משקאות מוגזים ומשקאות אנרגיה, הם מכניסים גז ולחץ לבטן."],
 ["🚫🥤","בלי קשית","שתייה עם קשית מכניסה אוויר, וזה מרגיש אחר כך כנפיחות."],
 ["🍬","שימו לב לסוכריות \"ללא סוכר\"","מסטיקים וסוכריות עם ממתיקים שנגמרים ב\"-ol\" (סורביטול, קסיליטול) עושים גזים אצל הרבה אנשים."],
 ["🥣","סיבים מסיסים, לאט לאט","שיבולת שועל וקיווי הם חברים של הבטן. מוסיפים בהדרגה ושותים מים לידם."],
 ["🚶‍♀️","תנועה קלה אחרי אוכל","הליכה קצרה עוזרת לבטן לעבוד יותר בנעימות."],
 ["😴","שינה = בטן רגועה","כשעייפים, הבטן מרגישה הכול חזק יותר. שינה טובה זה חלק מהטיפול."],
 ["📖","היומן הוא בלש","לא מסיקים מסקנות מאירוע אחד. מחפשים דפוסים שחוזרים, ובודקים יחד עם דיאטנית."]];

/* ================= helpers ================= */
const $=s=>document.querySelector(s);
const toast=m=>{const t=$("#toast");t.textContent=m;t.classList.add("show");
  clearTimeout(t._h);t._h=setTimeout(()=>t.classList.remove("show"),2200);};
const pad=n=>String(n).padStart(2,"0");
const fmtTime=d=>pad(d.getHours())+":"+pad(d.getMinutes());
const dayKey=d=>d.getFullYear()+"-"+pad(d.getMonth()+1)+"-"+pad(d.getDate());
function dayTitle(d){
  const now=new Date(), today=dayKey(now);
  const y=new Date(now); y.setDate(now.getDate()-1);
  const k=dayKey(d);
  const base="יום "+DAYS[d.getDay()]+" "+d.getDate()+"."+(d.getMonth()+1);
  if(k===today)return "היום · "+base;
  if(k===dayKey(y))return "אתמול · "+base;
  return base;
}
function localInputValue(d){return d.getFullYear()+"-"+pad(d.getMonth()+1)+"-"+pad(d.getDate())+"T"+pad(d.getHours())+":"+pad(d.getMinutes());}
const mealTypeName=v=>{const f=MEAL_TYPES.find(x=>x[0]===v);return f?f[1]:"";};

/* ================= header ================= */
(function(){
  const h=new Date().getHours();
  $("#hello").textContent = h<12?"בוקר טוב 🌅":h<18?"היי 💛":"ערב טוב 🌙";
  const n=new Date();
  $("#hSub").textContent="יום "+DAYS[n.getDay()]+", "+n.getDate()+"."+(n.getMonth()+1)+"."+n.getFullYear();
})();

/* ================= nav ================= */
document.querySelectorAll("nav button").forEach(b=>b.addEventListener("click",()=>{
  document.querySelectorAll("nav button").forEach(x=>x.classList.remove("on"));
  b.classList.add("on");
  document.querySelectorAll(".page").forEach(p=>p.classList.remove("active"));
  $("#"+b.dataset.p).classList.add("active");
  $("#fab").style.display = b.dataset.p==="p-diary" ? "flex" : "none";
  if(b.dataset.p==="p-sum")renderSummary();
  window.scrollTo(0,0);
}));

/* ================= timeline ================= */
function renderTimeline(){
  const tl=$("#timeline");
  if(!entries.length){
    tl.innerHTML='<div class="empty"><div class="big">🌸</div><p>היומן עוד ריק.<br>לוחצים על ＋ ומוסיפים ארוחה, הרגשה או הקלטה.</p></div>';
    return;
  }
  const sorted=[...entries].sort((a,b)=>new Date(b.ts)-new Date(a.ts));
  const groups={};
  sorted.forEach(e=>{const k=dayKey(new Date(e.ts));(groups[k]=groups[k]||[]).push(e);});
  let html="";
  Object.keys(groups).forEach(k=>{
    const d=new Date(groups[k][0].ts);
    html+='<div class="day-group"><h3 class="day-title">'+dayTitle(d)+'</h3><div class="tl">';
    groups[k].forEach(e=>{html+=entryHTML(e);});
    html+='</div></div>';
  });
  tl.innerHTML=html;
  tl.querySelectorAll(".e-del").forEach(b=>b.addEventListener("click",()=>{
    if(!confirm("למחוק את הרישום הזה?"))return;
    const id=b.dataset.id;
    const e=entries.find(x=>x.id===id);
    if(e&&e.kind==="voice")delClip(id);
    entries=entries.filter(x=>x.id!==id); save(); renderTimeline(); toast("נמחק");
  }));
  tl.querySelectorAll("audio[data-clip]").forEach(a=>{
    getClip(a.dataset.clip).then(blob=>{ if(blob)a.src=URL.createObjectURL(blob); });
  });
}
function esc(s){return (s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");}
function entryHTML(e){
  const t=fmtTime(new Date(e.ts));
  let emoji="🍽️", title="ארוחה", body="";
  if(e.kind==="meal"){
    emoji="🍽️"; title=mealTypeName(e.mealType)||"ארוחה";
    body=e.text?'<p class="e-text">'+esc(e.text)+'</p>':"";
  }else if(e.kind==="feel"){
    emoji="💜"; title="הרגשה";
    const good=(e.symptoms||[]).includes("הכול טוב 💛");
    let chips="";
    (e.symptoms||[]).forEach(s=>{
      chips+='<span class="chip '+(s==="הכול טוב 💛"?"good":(e.sev?("sev"+e.sev):""))+'">'+esc(s)+'</span>';});
    if(!good&&e.sev)chips+='<span class="chip sev'+e.sev+'">עוצמה: '+SEVS.find(s=>s[0]==e.sev)[1]+'</span>';
    (e.context||[]).forEach(c=>{chips+='<span class="chip" style="background:var(--sage-soft);color:#4E7A4B;">'+esc(c)+'</span>';});
    body=(chips?'<div class="chips">'+chips+'</div>':"")+(e.text?'<p class="e-text">'+esc(e.text)+'</p>':"");
  }else if(e.kind==="voice"){
    emoji="🎙️"; title=e.text?esc(e.text):"הקלטה";
    body='<audio controls preload="none" data-clip="'+e.id+'"></audio>';
  }else{
    emoji="📝"; title="פתק";
    body=e.text?'<p class="e-text">'+esc(e.text)+'</p>':"";
  }
  return '<div class="entry k-'+e.kind+'"><div class="e-top"><span class="e-emoji">'+emoji+
    '</span><span class="e-title">'+title+'</span><span class="e-time">'+t+
    '</span><button class="e-del" data-id="'+e.id+'" aria-label="מחיקה">✕</button></div>'+body+'</div>';
}

/* ================= add sheet ================= */
let curKind="meal", sel={mealType:"boker", symptoms:[], sev:null, context:[]};
let recState={rec:null, chunks:[], blob:null, mime:"", timer:null, sec:0, stream:null};

function buildPick(el,items,multi,cur,onSet){
  el.innerHTML="";
  items.forEach(it=>{
    const[v,label]=Array.isArray(it)?it:[it,it];
    const b=document.createElement("button");
    b.type="button"; b.textContent=label;
    const isOn=multi?cur().includes(v):cur()===v;
    if(isOn)b.classList.add("on");
    b.addEventListener("click",()=>{onSet(v);buildPick(el,items,multi,cur,onSet);});
    el.appendChild(b);
  });
}
function refreshPicks(){
  buildPick($("#mealTypePick"),MEAL_TYPES,false,()=>sel.mealType,v=>sel.mealType=v);
  buildPick($("#sympPick"),SYMPTOMS,true,()=>sel.symptoms,v=>{
    if(v==="הכול טוב 💛"){sel.symptoms=sel.symptoms.includes(v)?[]:[v];sel.sev=null;}
    else{sel.symptoms=sel.symptoms.filter(x=>x!=="הכול טוב 💛");
      sel.symptoms.includes(v)?sel.symptoms=sel.symptoms.filter(x=>x!==v):sel.symptoms.push(v);}
    $("#sevLabel").style.display=sel.symptoms.length&&!sel.symptoms.includes("הכול טוב 💛")?"":"none";
    $("#sevPick").style.display=$("#sevLabel").style.display;
  });
  buildPick($("#sevPick"),SEVS,false,()=>sel.sev,v=>sel.sev=v);
  buildPick($("#ctxPick"),CTX,true,()=>sel.context,v=>{
    sel.context.includes(v)?sel.context=sel.context.filter(x=>x!==v):sel.context.push(v);});
}
function openSheet(kind){
  curKind=kind||"meal";
  sel={mealType:guessMealType(), symptoms:[], sev:null, context:[]};
  ["mealText","feelText","voiceText","noteText"].forEach(id=>$("#"+id).value="");
  resetRec();
  refreshPicks(); showKind();
  $("#whenIn").value=localInputValue(new Date());
  $("#overlay").classList.add("show"); $("#sheet").classList.add("show");
}
function closeSheet(){ $("#overlay").classList.remove("show"); $("#sheet").classList.remove("show"); stopRec(true); }
function guessMealType(){const h=new Date().getHours();
  return h<10?"boker":h<12?"school":h<16?"tsohor":h<18?"nash":"erev";}
function showKind(){
  document.querySelectorAll("#kindSeg button").forEach(b=>b.classList.toggle("on",b.dataset.k===curKind));
  ["meal","feel","voice","note"].forEach(k=>{$("#f-"+k).hidden=k!==curKind;});
}
document.querySelectorAll("#kindSeg button").forEach(b=>b.addEventListener("click",()=>{curKind=b.dataset.k;showKind();}));
$("#fab").addEventListener("click",()=>openSheet());
$("#overlay").addEventListener("click",closeSheet);

/* ---------- recorder ---------- */
function pickMime(){
  const list=["audio/mp4","audio/webm;codecs=opus","audio/webm"];
  for(const m of list){ if(window.MediaRecorder&&MediaRecorder.isTypeSupported&&MediaRecorder.isTypeSupported(m))return m; }
  return "";
}
function resetRec(){
  stopRec(true);
  recState={rec:null,chunks:[],blob:null,mime:"",timer:null,sec:0,stream:null};
  $("#recBtn").classList.remove("live"); $("#recBtn").textContent="🎙️";
  $("#recTime").textContent="0:00"; $("#recPrev").hidden=true; $("#recPrev").removeAttribute("src");
}
function stopRec(silent){
  if(recState.rec&&recState.rec.state!=="inactive"){try{recState.rec.stop();}catch(e){}}
  if(recState.stream){recState.stream.getTracks().forEach(t=>t.stop());recState.stream=null;}
  clearInterval(recState.timer);
  if(!silent){$("#recBtn").classList.remove("live");$("#recBtn").textContent="🎙️";}
}
$("#recBtn").addEventListener("click",async()=>{
  if(recState.rec&&recState.rec.state==="recording"){ stopRec(false); return; }
  if(!navigator.mediaDevices||!window.MediaRecorder){ toast("הקלטה לא נתמכת בדפדפן הזה"); return; }
  try{
    const stream=await navigator.mediaDevices.getUserMedia({audio:true});
    recState.stream=stream; recState.chunks=[]; recState.mime=pickMime();
    const rec=recState.mime?new MediaRecorder(stream,{mimeType:recState.mime}):new MediaRecorder(stream);
    recState.rec=rec;
    rec.ondataavailable=e=>{if(e.data&&e.data.size)recState.chunks.push(e.data);};
    rec.onstop=()=>{
      recState.blob=new Blob(recState.chunks,{type:recState.mime||"audio/mp4"});
      const url=URL.createObjectURL(recState.blob);
      $("#recPrev").src=url; $("#recPrev").hidden=false;
      if(recState.stream){recState.stream.getTracks().forEach(t=>t.stop());recState.stream=null;}
    };
    rec.start();
    recState.sec=0; $("#recTime").textContent="0:00";
    recState.timer=setInterval(()=>{recState.sec++;
      $("#recTime").textContent=Math.floor(recState.sec/60)+":"+pad(recState.sec%60);
      if(recState.sec>=180)stopRec(false);},1000);
    $("#recBtn").classList.add("live"); $("#recBtn").textContent="⏹";
  }catch(err){ toast("אין גישה למיקרופון. בודקים בהגדרות ספארי"); }
});

/* ---------- save ---------- */
$("#saveBtn").addEventListener("click",async()=>{
  const when=$("#whenIn").value?new Date($("#whenIn").value):new Date();
  const e={id:uid(), ts:when.toISOString(), kind:curKind};
  if(curKind==="meal"){
    e.mealType=sel.mealType; e.text=$("#mealText").value.trim();
    if(!e.text){toast("מה אכלת? כמה מילים 🙂");return;}
  }else if(curKind==="feel"){
    e.symptoms=[...sel.symptoms]; e.sev=sel.sev; e.context=[...sel.context];
    e.text=$("#feelText").value.trim();
    if(!e.symptoms.length&&!e.text){toast("בוחרים לפחות הרגשה אחת");return;}
  }else if(curKind==="voice"){
    stopRec(false);
    if(!recState.blob){toast("קודם מקליטים משהו קטן 🎙️");return;}
    e.text=$("#voiceText").value.trim();
    const ok=await putClip(e.id,recState.blob);
    if(!ok){toast("שמירת ההקלטה נכשלה");return;}
  }else{
    e.text=$("#noteText").value.trim();
    if(!e.text){toast("כותבים משהו קטן 🙂");return;}
  }
  entries.push(e); save(); closeSheet(); renderTimeline(); toast("נשמר ביומן 💛");
  burst(window.innerWidth/2, window.innerHeight-140);
});

/* ================= meals ================= */
const CAT_COLORS={
 "בוקר":["#F7B24C","#FEF0DA"], "צהריים":["#F4867C","#FFE9E4"], "ערב":["#A98BE0","#F1EAFC"],
 "נשנושים":["#69BFA5","#E3F5EC"], "קינוחים":["#EC6FA8","#FDE7F2"], "לבית הספר":["#5E9BE6","#E4EFFC"]};
function applyAccent(){
  const [c,s]=CAT_COLORS[curCat]||CAT_COLORS["בוקר"];
  const list=$("#mealList");
  list.style.setProperty("--acc",c); list.style.setProperty("--acc-soft",s);
  const row=$("#catRow"); row.style.setProperty("--acc",c); row.style.setProperty("--acc-soft",s);
}
function burst(x,y){
  const em=["💛","💗","🌸","✨","💜"];
  for(let i=0;i<7;i++){
    const h=document.createElement("span");
    h.className="heart"; h.textContent=em[i%em.length];
    h.style.left=(x-8)+"px"; h.style.top=(y-8)+"px";
    h.style.setProperty("--hx",(Math.random()*90-45)+"px");
    h.style.setProperty("--hr",(Math.random()*60-30)+"deg");
    h.style.animationDelay=(i*0.04)+"s";
    document.body.appendChild(h);
    setTimeout(()=>h.remove(),1400);
  }
}
let curCat=Object.keys(MEALS)[0];
function renderCats(){
  const row=$("#catRow"); row.innerHTML="";
  Object.keys(MEALS).forEach(c=>{
    const b=document.createElement("button");
    b.textContent=c; if(c===curCat)b.classList.add("on");
    b.addEventListener("click",()=>{curCat=c;renderCats();renderMeals();});
    row.appendChild(b);
  });
}
function mealCard(m){
  const swaps=(m.s||[]).filter(x=>x!=="-");
  return '<div class="meal-card"><div class="m-head"><span class="m-emoji">'+m.e+
   '</span><span class="m-name">'+esc(m.n)+'</span></div><ul class="m-parts">'+
   m.p.map(x=>'<li>'+esc(x)+'</li>').join("")+'</ul>'+
   (swaps.length?'<div class="m-swaps-t">אפשר להחליף / להוסיף:</div><div class="chips">'+
     swaps.map(x=>'<span class="chip">'+esc(x)+'</span>').join("")+'</div>':"")+
   '<button class="m-log" data-n="'+esc(m.n)+'">✔ אכלתי את זה, לרשום ביומן</button></div>';
}
function bindLog(scope){
  scope.querySelectorAll(".m-log").forEach(b=>b.addEventListener("click",ev=>{
    entries.push({id:uid(), ts:new Date().toISOString(), kind:"meal",
      mealType:guessMealType(), text:b.dataset.n});
    save(); renderTimeline(); toast("נרשם ביומן 💛");
    const r=b.getBoundingClientRect(); burst(r.left+r.width/2, r.top);
  }));
}
function renderMeals(){
  applyAccent();
  const list=$("#mealList");
  list.innerHTML=MEALS[curCat].map(mealCard).join("");
  bindLog(list);
}
$("#shuffleBtn").addEventListener("click",()=>{
  applyAccent();
  const arr=MEALS[curCat]; const m=arr[Math.floor(Math.random()*arr.length)];
  const list=$("#mealList");
  list.innerHTML=mealCard(m)+'<p style="text-align:center;color:var(--soft);font-size:.85rem;">🎲 הגרלה מתוך '+curCat+' · לחיצה נוספת מגרילה שוב</p>'+MEALS[curCat].filter(x=>x!==m).map(mealCard).join("");
  bindLog(list);
  window.scrollTo({top:0,behavior:"smooth"});
});

/* ================= tips + breathing ================= */
$("#tipList").innerHTML=TIPS.map(t=>'<div class="tip"><span class="t-e">'+t[0]+
  '</span><p><b>'+t[1]+'</b>'+t[2]+'</p></div>').join("");
let bRun=false,bT=null;
$("#bStart").addEventListener("click",()=>{
  const c=$("#bCircle"),tx=$("#bText"),btn=$("#bStart");
  if(bRun){bRun=false;clearTimeout(bT);btn.textContent="התחלה";c.style.transform="scale(1)";c.textContent="מוכנה?";tx.textContent="שאיפה 4 · החזקה 4 · נשיפה 6";return;}
  bRun=true; btn.textContent="עצירה";
  const cycle=()=>{
    if(!bRun)return;
    tx.textContent="שאיפה... 🌬️"; c.textContent="4"; c.style.transition="transform 4s ease-in-out"; c.style.transform="scale(1.45)";
    bT=setTimeout(()=>{ if(!bRun)return;
      tx.textContent="מחזיקים..."; c.textContent="4";
      bT=setTimeout(()=>{ if(!bRun)return;
        tx.textContent="נשיפה ארוכה... 😌"; c.textContent="6"; c.style.transition="transform 6s ease-in-out"; c.style.transform="scale(1)";
        bT=setTimeout(cycle,6200);
      },4000);
    },4200);
  };
  cycle();
});

/* ================= summary ================= */
function last14(){ const cut=Date.now()-14*864e5; return entries.filter(e=>new Date(e.ts)>=cut); }
function renderSummary(){
  const es=last14();
  const feels=es.filter(e=>e.kind==="feel");
  const sympDays=new Set(), goodDays=new Set(), counts={};
  feels.forEach(e=>{
    const k=dayKey(new Date(e.ts));
    if((e.symptoms||[]).includes("הכול טוב 💛"))goodDays.add(k);
    (e.symptoms||[]).forEach(s=>{ if(s!=="הכול טוב 💛"){sympDays.add(k);counts[s]=(counts[s]||0)+1;} });
  });
  let top="—",n=0; Object.keys(counts).forEach(s=>{if(counts[s]>n){n=counts[s];top=s;}});
  $("#statGrid").innerHTML=
    '<div class="stat"><div class="n">'+es.filter(e=>e.kind==="meal").length+'</div><div class="l">ארוחות ביומן</div></div>'+
    '<div class="stat"><div class="n">'+goodDays.size+'</div><div class="l">ימים של "הכול טוב" 💛</div></div>'+
    '<div class="stat"><div class="n">'+sympDays.size+'</div><div class="l">ימים עם תסמינים</div></div>'+
    '<div class="stat"><div class="n" style="font-size:1.05rem;line-height:2.2;">'+esc(top)+'</div><div class="l">התסמין הנפוץ</div></div>';
}
function summaryText(){
  const es=[...last14()].sort((a,b)=>new Date(a.ts)-new Date(b.ts));
  if(!es.length)return "אין רישומים ב-14 הימים האחרונים.";
  let out="סיכום יומן בטן רגועה, 14 ימים אחרונים:\n";
  let curDay="";
  es.forEach(e=>{
    const d=new Date(e.ts), k=dayKey(d);
    if(k!==curDay){curDay=k; out+="\n📅 "+dayTitle(d)+"\n";}
    let line=fmtTime(d)+" ";
    if(e.kind==="meal")line+="🍽️ "+(mealTypeName(e.mealType)||"ארוחה")+": "+(e.text||"");
    else if(e.kind==="feel"){
      line+="💜 "+((e.symptoms||[]).join(", ")||"הרגשה");
      if(e.sev)line+=" (עוצמה: "+SEVS.find(s=>s[0]==e.sev)[1]+")";
      if(e.context&&e.context.length)line+=" | הקשר: "+e.context.join(", ");
      if(e.text)line+=" | "+e.text;
    }
    else if(e.kind==="voice")line+="🎙️ הקלטה"+(e.text?": "+e.text:"");
    else line+="📝 "+(e.text||"");
    out+=line+"\n";
  });
  return out;
}
$("#shareBtn").addEventListener("click",async()=>{
  const txt=summaryText();
  if(navigator.share){ try{await navigator.share({title:"סיכום בטן רגועה",text:txt});return;}catch(e){} }
  try{await navigator.clipboard.writeText(txt);toast("הסיכום הועתק 📋");}
  catch(e){toast("לא הצלחתי להעתיק");}
});
$("#backupBtn").addEventListener("click",()=>{
  const blob=new Blob([JSON.stringify(entries,null,1)],{type:"application/json"});
  const a=document.createElement("a");
  a.href=URL.createObjectURL(blob);
  a.download="beten-ragua-backup-"+dayKey(new Date())+".json";
  a.click(); toast("קובץ הגיבוי ירד 💾");
});
$("#restoreBtn").addEventListener("click",()=>$("#restoreFile").click());
$("#restoreFile").addEventListener("change",e=>{
  const f=e.target.files[0]; if(!f)return;
  const r=new FileReader();
  r.onload=()=>{try{
    const arr=JSON.parse(r.result);
    if(!Array.isArray(arr))throw 0;
    entries=arr; save(); renderTimeline(); renderSummary(); toast("היומן שוחזר ✨");
  }catch(err){toast("הקובץ לא תקין");}};
  r.readAsText(f); e.target.value="";
});

/* ================= boot ================= */
renderCats(); renderMeals(); renderTimeline();
if("serviceWorker" in navigator){ navigator.serviceWorker.register("sw.js").catch(()=>{}); }
</script>
</body>
</html>
